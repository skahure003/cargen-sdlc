# Django settings
DEBUG=1
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,sdlc.cargen.org
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://sdlc.cargen.org

# Database
# Use either DATABASE_URL or the DB_* variables below.
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=cargen_sdlc
DB_USER=postgres
DB_PASSWORD=
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Runtime
PORT=8000

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=
SERVER_EMAIL=
APP_BASE_URL=http://127.0.0.1:8000
EMAIL_APPROVAL_MAX_AGE=86400
